# Server
PORT=8787
SERVE_STATIC=true
FRONTEND_BASE_PATH=/health-ac/

# Local API paths
SYNC_API_PATH=/api/sheets-sync
HEALTH_API_PATH=/api/health

# Google Sheets webhook (Apps Script)
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_DEPLOYMENT_ID/exec
SHEETS_WRITE_TOKEN=REPLACE_WITH_RANDOM_TOKEN

# Optional security for cross-origin deployments (comma-separated)
# SYNC_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Proxy limits/timeouts
SYNC_PROXY_TIMEOUT_MS=12000
SYNC_PROXY_MAX_ITEMS=500
SYNC_PROXY_MAX_BODY_BYTES=1500000

# Frontend build default for backend mode (align with current base)
VITE_SYNC_API_ENDPOINT=/health-ac/api/sheets-sync
